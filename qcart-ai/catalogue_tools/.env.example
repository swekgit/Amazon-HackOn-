# Rainforest API
RAINFOREST_API_KEY=your_rainforest_api_key_here
AMAZON_DOMAIN=amazon.in

# Google Custom Search API
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
MAX_GOOGLE_REQUESTS=100
GOOGLE_RATE_LIMIT=1

# Bing Image Search API
BING_API_KEY=your_bing_api_key_here
MAX_BING_REQUESTS=100
BING_RATE_LIMIT=1

# SerpAPI
SERP_API_KEY=your_serpapi_key_here
MAX_SERP_REQUESTS=100
SERP_RATE_LIMIT=1

# AWS Configuration
AWS_REGION=ap-south-1
S3_BUCKET=qcart-product-images
S3_FOLDER=products

# CloudFront (set after creating distribution)
CLOUDFRONT_URL=https://cdn.qcart.ai

# Pipeline Modes
DRY_RUN=true
TEST_MODE=true
TEST_PRODUCTS=5

# Limits
MAX_REQUESTS_PER_RUN=300
RATE_LIMIT_SECONDS=1.5
MIN_CONFIDENCE=45
MAX_RETRIES=3
DOWNLOAD_THREADS=4

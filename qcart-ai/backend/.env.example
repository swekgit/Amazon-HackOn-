# ─── AWS / Bedrock ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Titan embedding model (used by catalog.embed and build_index)
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBED_DIM=1024
BEDROCK_EMBED_REGION=us-east-1

# ─── OpenSearch (vector retrieval) ───────────────────────────────────────────
OPENSEARCH_ENDPOINT=search-your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=qcart-products
OPENSEARCH_REGION=us-east-1

# ─── Ingredient resolver gates (calibrated — tune via catalog_regression.py) ──
SIM_FLOOR=0.2996
RESOLVE_MARGIN=1.05
RESOLVE_K=40
RESOLVE_GROUP_EPSILON=0.01

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/qcart?retryWrites=true&w=majority

# ─── LLM (Nova Lite / cart generation via model_router) ────────────────────
# See model_router.py for NOVA_LITE_* / LLAMA_* vars if needed.

# ─── Optional: Anthropic (legacy) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

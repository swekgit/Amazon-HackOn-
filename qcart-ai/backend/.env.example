# Get a key from https://console.anthropic.com  ->  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional: swap the model. Use haiku for fastest demo, sonnet for best quality.
# CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# MongoDB Atlas connection string
# Get from: Atlas Console → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/qcart?retryWrites=true&w=majority
